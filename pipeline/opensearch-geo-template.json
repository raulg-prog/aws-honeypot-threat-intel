{
  "index_patterns": ["cowrie-geo-*"],
  "template": {
    "mappings": {
      "properties": {
        "geoip": {
          "properties": {
            "geo": {
              "properties": {
                "location": { "type": "geo_point" }
              }
            }
          }
        }
      }
    }
  }
}
